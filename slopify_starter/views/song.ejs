
<!doctype html>
<html>

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
</head>

<body>

    <div class="app-layout">
        <aside class="sidebar">
    <div class="sidebar-logo">
        <h1 class="sidebar-logo-title">
            <img src="/img/slopifylogo.png" class="sidebar-logo-img" alt="Slopify Logo" />
            <span class="sidebar-logo-text">SLOPIFY</span>
        </h1>
    </div>
    <div class="credits-card">
        <div class="credits-label">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                class="credits-icon">
                <circle cx="12" cy="12" r="10"></circle>
                <path
                    d="M9 11c0-1.66 1.34-3 3-3s3 1.34 3 3c0 1.5-.92 2.79-2.25 3.38v.62c0 .41-.34.75-.75.75s-.75-.34-.75-.75v-.5c0-.41.34-.75.75-.75.41 0 .75-.34.75-.75 0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5c0 .41-.34.75-.75.75s-.75-.34-.75-.75zm3 5.5c.41 0 .75.34.75.75s-.34.75-.75.75-.75-.34-.75-.75.34-.75.75-.75z">
                </path>
            </svg>
            <span class="credits-label-text">Credits</span>
        </div>
        <div class="credits-amount">
            <span class="credits-value">
                200
            </span>
            <span class="credits-currency">₿</span>
        </div>
        <div class="credits-add-btn-wrapper">
            <a class="btn-add-coins" href="/billing">Add Coins</a>
        </div>
    </div>
    <nav class="sidebar-nav">
        <a class="sidebar-nav-link" href="/songs">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="nav-icon">
                <path d="M9 18V5l12-2v13"></path>
                <circle cx="6" cy="18" r="3"></circle>
                <circle cx="18" cy="16" r="3"></circle>
            </svg>
            Songs
        </a>
    </nav>
    <div class="sidebar-footer">
        <button class="logout-btn">
            <div class="logout-btn-inner">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="logout-icon">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                <span class="logout-text">Logout</span>
            </div>
        </button>
    </div>
</aside>


        <main class="main-content">
            <div class="song-detail">
                <div class="song-detail-grid">
                    <div class="song-cover-wrapper">
                        <div class="song-cover">
                            <img alt="Windows 95 - Lo-Fi chill mix" class="song-cover-img" src="https://files.assimilate.be/music/windows95LofiChillMix.jpg">
                            <div class="play-btn">
                                <svg role="img" height="24" width="24" aria-hidden="true" viewBox="0 0 24 24"
                                    fill="currentColor" class="play-icon">
                                    <path
                                        d="m7.05 3.606 13.49 7.788a.7.7 0 0 1 0 1.212L7.05 20.394A.7.7 0 0 1 6 19.788V4.212a.7.7 0 0 1 1.05-.606z">
                                    </path>
                                </svg>
                            </div>
                            
                        </div>
                    </div>
                    <div class="song-info">
                        <div class="song-type-badge">
                            Music Video
                        </div>
                        <h1 class="song-title">
                            Windows 95 - Lo-Fi chill mix
                        </h1>
                        <p class="song-desc">
                            Windows 95 - Lo-Fi chill mix
                        </p>
                        <div class="song-meta-list">
                            <div class="song-meta-item">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round" class="meta-icon meta-icon-green">
                                    <path d="M9 18V5l12-2v13"></path>
                                    <circle cx="6" cy="18" r="3"></circle>
                                    <circle cx="18" cy="16" r="3"></circle>
                                </svg>
                                <span class="song-meta-label">
                                    AI Music Video
                                </span>
                            </div>
                            <div class="song-meta-item">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round" class="meta-icon meta-icon-green">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                                <span class="song-meta-label">
                                    2025-03-29
                                </span>
                            </div>
                            <div class="song-meta-item">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round" class="meta-icon meta-icon-yellow">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <path
                                        d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z">
                                    </path>
                                </svg>
                                <span class="song-meta-label">
                                    100 Credits
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="youtube-section">
                    <div class="youtube-inner">
                        <div class="youtube-header">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                                class="youtube-icon">
                                <path
                                    d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z">
                                </path>
                            </svg>
                            <h2 class="youtube-title">Watch on YouTube</h2>
                        </div>
                        <div class="youtube-embed">
                            <iframe width="100%" height="100%"
                                src="https://www.youtube.com/embed/lemphxe-s1w"
                                title="Windows 95 - Lo-Fi chill mix" frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen="" class="youtube-iframe"></iframe>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>

</html>
