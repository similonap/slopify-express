
<!doctype html>
<html>

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
    <div class="page-center">
        <div class="billing-container">

            

            <div class="card-border">
                <div class="card-inner">
                    <div class="card-header">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                            fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                            stroke-linejoin="round" class="card-header-icon">
                            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                            <line x1="2" y1="10" x2="22" y2="10"></line>
                        </svg>
                        <h1 class="card-title">Add Coins</h1>
                    </div>
                    <p class="card-subtitle">Demo mode: payment details are pre-filled and read-only.</p>
                    <form class="billing-form" method="post" action="/billing">
                        <div>
                            <label class="form-label">Cardholder Name</label>
                            <input class="form-input" readonly="" type="text" value="John Demo">
                        </div>
                        <div>
                            <label class="form-label">Card Number</label>
                            <input class="form-input" readonly="" type="text" value="4242 4242 4242 4242">
                        </div>
                        <div class="form-grid-2">
                            <div>
                                <label class="form-label">Expiry</label>
                                <input class="form-input" readonly="" type="text" value="12/29">
                            </div>
                            <div>
                                <label class="form-label">CVC</label>
                                <input class="form-input" readonly="" type="text" value="123">
                            </div>
                        </div>
                        <div>
                            <label class="form-label">Amount</label>
                            <select name="amount" class="form-select">
                                <option value="100" class="select-option">100 Coins</option>
                                <option value="250" class="select-option" selected="">250 Coins</option>
                                <option value="500" class="select-option">500 Coins</option>
                                <option value="1000" class="select-option">1000 Coins</option>
                            </select>
                        </div>
                        <button type="submit" class="btn-primary">Add Coins</button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</body>

</html>
