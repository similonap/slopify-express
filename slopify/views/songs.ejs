<%- include("partials/header") %>
    <div class="app-layout">
        <%- include("partials/aside") %>

        <main class="main-content">
            <div class="toolbar">
                <div class="search-wrapper">
                    <form class="pill-bar search-form">
                        <div class="pill-bar-inner">
                            <span class="bar-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round" class="icon-sm">
                                    <circle cx="11" cy="11" r="7"></circle>
                                    <line x1="16.65" y1="16.65" x2="21" y2="21"></line>
                                </svg>
                            </span>
                            <input
                                class="search-input"
                                type="search" placeholder="Search songs, artists, albums..." name="q"
                                value="<%= q %>" />
                            <input type="hidden" value="<%= sortField %>" name="sortField">
                            <input type="hidden" value="<%= sortDirection %>" name="sortDirection">
                        </div>
                        <button type="submit" class="btn-search">Search</button>
                    </form>
                </div>
                <div class="sort-wrapper">
                    <div class="pill-bar">
                        <div class="pill-bar-inner">
                            <span class="bar-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round" class="icon-sm">
                                    <path d="M3 6h18"></path>
                                    <path d="M7 12h10"></path>
                                    <path d="M10 18h4"></path>
                                </svg>
                            </span>
                            <form>
                                <input type="hidden" name="q" value="<%= q %>" />
                                <select id="sortField" name="sortField"
                                    class="sort-select"
                                    onchange="this.form.submit()">
                                    <option value="title" class="select-option" selected="" <%=sortField==='title'
                                        ? 'selected' : '' %>>Title</option>
                                    <option value="owned" class="select-option" <%=sortField==='owned' ? 'selected'
                                        : '' %>>Owned</option>
                                    <option value="publish_date" class="select-option" <%=sortField==='publish_date'
                                        ? 'selected' : '' %>>Publish Date</option>
                                </select>
                                <span class="sort-divider">|</span>
                                <select id="sortDirection" name="sortDirection"
                                    class="sort-select"
                                    onchange="this.form.submit()">
                                    <option value="asc" class="select-option" <%=sortDirection==='asc' ? 'selected'
                                        : '' %>>ASC</option>
                                    <option value="desc" class="select-option" <%=sortDirection==='desc' ? 'selected'
                                        : '' %>>DESC</option>
                                </select>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <div class="songs-grid">

                <% for (let song of songs) { %>
                    <div class="song-card">
                        <div class="song-card-thumb">
                            <img src="<%= song.thumbnail %>" alt="<%= song.title %>" loading="lazy" width="200"
                                height="200" class="song-card-img" />
                            <% if (!song.owned) { %>
                                <form action="buy" method="post">
                                    <input type="hidden" name="id" value="<%= song.id %>">
                                    <button class="btn-buy"><%= song.credits %> credits</button>
                                </form>
                            <% } else { %>
                                <div class="badge-owned">Owned</div>
                            <% } %>
                        </div>
                        <a href="/songs/<%= song.id %>">
                            <div>
                                <h2 class="song-card-title" title="<%= song.title %>">
                                    <%= song.title %>
                                </h2>
                                <p class="song-card-desc" title="<%= song.title %>">
                                    <%= song.description %>
                                </p>
                                <div class="song-card-meta">
                                    <span><%= song.more_information.genre %></span>
                                    <span><%= song.more_information.publish_date.substring(0,4) %></span>
                                </div>
                            </div>
                        </a>
                    </div>
                <% } %>

            </div>
        </main>
    </div>
<%- include("partials/footer") %>
