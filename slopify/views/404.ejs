<!doctype html>
<html>

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
    <div class="page-center">
        <div class="error-page-container">
            <div class="error-card">
                <div class="error-card-inner">

                    <div class="error-icon-wrapper">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="error-icon-svg">
                            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="9.5" y1="12.5" x2="14.5" y2="17.5"></line>
                            <line x1="14.5" y1="12.5" x2="9.5" y2="17.5"></line>
                        </svg>
                    </div>

                    <h1 class="error-code">
                        4<span class="error-highlight">0</span>4
                    </h1>
                    <h2 class="error-title">Page Not Found</h2>
                    <p class="error-desc">
                        We couldn't find the page you're looking for. It might have been moved, deleted, or perhaps the URL is incorrect.
                    </p>

                    <a href="/" class="btn-home">Back to Home</a>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
